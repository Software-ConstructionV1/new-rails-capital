<h1>Books</h1>

<p><%= link_to "New Book", new_book_path, class: "button" %></p>

<table>
  <thead>
    <tr>
      <th>Title</th>
      <th>Author</th>
      <th>Description</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @books.each do |book| %>
      <tr>
        <td><%= link_to book.title, book %></td>
        <td><%= book.author %></td>
        <td><%= truncate(book.description, length: 100) %></td>
        <td>
          <%= link_to "Edit", edit_book_path(book) %> |
          <%= link_to "Destroy", book, method: :delete, data: { confirm: "Are you sure?" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

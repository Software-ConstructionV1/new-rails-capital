<h1>All Books</h1>

<% @books.each do |book| %>
  <p>
    <%= book.title %> (<%= book.author %>)
    <%= link_to "Show", book_path(book) %>
    <%= link_to "Edit", edit_book_path(book) %>
    <%= link_to "Delete", book_path(book), data: { turbo_method: :delete } %>
  </p>
<% end %>

<%= link_to "New Book", new_book_path %>
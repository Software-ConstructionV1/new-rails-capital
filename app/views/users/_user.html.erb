<div id="<%= dom_id user %>">
  <div>
    <strong>Name:</strong>
    <%= user.name %>
  </div>

  <div>
    <strong>Email:</strong>
    <%= user.email %>
  </div>

  <div>
    <strong>DOB:</strong>
    <%= user.dob %>
  </div>

  <div>
    <strong>Phone Number:</strong>
    <%= user.phone_number %>
  </div>

  <div>
    <strong>Address:</strong>
    <%= user.address %>
  </div>

</div>
